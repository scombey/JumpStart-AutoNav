{
  "name": "@scombey/jumpstart-mode",
  "version": "2.0.0-rc.1",
  "description": "Spec-driven agentic engineering framework that transforms ideas into production code through AI-powered sequential phases",
  "type": "module",
  "keywords": [
    "jumpstart",
    "framework",
    "ai-agent",
    "scaffold",
    "copilot",
    "claude",
    "cursor",
    "spec-driven",
    "agentic",
    "modules",
    "skills",
    "extensible"
  ],
  "author": "Jo Otey <jootey@outlook.com>",
  "contributors": [
    "Samuel Combey <combeysamuel@gmail.com>"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scombey/jumpstart-mode.git"
  },
  "bin": {
    "jumpstart-mode": "./dist/cli/bin.mjs",
    "jumpstart": "./bin/bootstrap.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli/main.d.mts",
      "import": "./dist/cli/main.mjs"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.mts",
      "import": "./dist/lib/*.mjs"
    },
    "./errors": {
      "types": "./dist/lib/errors.d.mts",
      "import": "./dist/lib/errors.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    ".jumpstart",
    ".github",
    "bin/bootstrap.js",
    "dist/**/*.mjs",
    "dist/**/*.d.mts",
    "AGENTS.md",
    "CLAUDE.md",
    ".cursorrules",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/test-schema.test.js tests/test-spec-quality.test.js",
    "test:integration": "vitest run tests/test-handoffs.test.js",
    "test:regression": "vitest run tests/test-regression.test.js",
    "test:requirements": "vitest run tests/test-requirements-extractor.test.js",
    "test:all": "vitest run",
    "test:e2e": "node dist/cli/bin.mjs holodeck --all",
    "test:e2e:scenario": "node dist/cli/bin.mjs holodeck",
    "test:e2e:verify": "node dist/cli/bin.mjs holodeck --all --verify-subagents",
    "holodeck": "node dist/cli/bin.mjs holodeck",
    "holodeck:list": "node dist/cli/bin.mjs holodeck --list",
    "emulate": "node dist/cli/bin.mjs headless",
    "emulate:mock": "node dist/cli/bin.mjs headless --mock",
    "emulate:architect": "node dist/cli/bin.mjs headless --agent architect --persona compliant-user",
    "emulate:full": "node dist/cli/bin.mjs headless --agent challenger,analyst,pm,architect",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check:public-any": "node scripts/check-public-any.mjs",
    "check:process-exit": "node scripts/check-process-exit.mjs",
    "check:coverage-ratchet": "node scripts/check-coverage-ratchet.mjs",
    "check:dist-exports": "node scripts/check-dist-exports.mjs",
    "check:return-shapes": "node scripts/check-return-shapes.mjs",
    "verify-baseline": "node scripts/verify-baseline.mjs",
    "prepublishOnly": "git diff --quiet HEAD || (echo 'Refusing to publish: working tree is dirty. Commit or stash changes first.' && exit 1) && npm run build && node dist/cli/bin.mjs --help"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "citty": "^0.2.2",
    "dotenv": "^17.3.1",
    "openai": "^6.23.0",
    "prompts": "^2.4.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "json-schema-to-zod": "^2.6.0",
    "tsdown": "0.21.10",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
