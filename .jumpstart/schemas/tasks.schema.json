{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "jumpstart://tasks",
  "title": "Jump Start Implementation Tasks Schema",
  "description": "Schema for validating implementation plan task structures.",
  "type": "object",
  "required": ["metadata", "milestones"],
  "properties": {
    "metadata": {
      "$ref": "spec-metadata.schema.json"
    },
    "plan_summary": {
      "type": "object",
      "properties": {
        "total_milestones": { "type": "integer", "minimum": 1 },
        "total_tasks": { "type": "integer", "minimum": 1 },
        "tasks_completed": { "type": "integer", "minimum": 0 },
        "status": {
          "type": "string",
          "enum": ["Not Started", "In Progress", "Complete"]
        }
      }
    },
    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "tasks"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^M\\d+$",
            "description": "Milestone identifier (e.g., 'M1')."
          },
          "name": { "type": "string" },
          "goal": { "type": "string" },
          "prd_stories": {
            "type": "array",
            "items": { "type": "string" },
            "description": "PRD story IDs included in this milestone."
          },
          "tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "title", "component", "files"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^M\\d+-T\\d+$",
                  "description": "Task identifier (e.g., 'M1-T01')."
                },
                "title": { "type": "string" },
                "component": { "type": "string" },
                "story_ref": { "type": "string" },
                "files": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "File paths to create or modify."
                },
                "dependencies": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Task IDs that must be completed first."
                },
                "description": { "type": "string" },
                "tests_required": { "type": "string" },
                "done_when": { "type": "string" },
                "execution_order": {
                  "type": "string",
                  "enum": ["S", "P", "R", "M", "D"],
                  "description": "S=Sequential, P=Parallel, R=Refactor, M=Migration, D=Documentation."
                },
                "status": {
                  "type": "string",
                  "enum": ["Not Started", "In Progress", "Complete", "Blocked"],
                  "default": "Not Started"
                }
              }
            }
          }
        }
      }
    }
  }
}
