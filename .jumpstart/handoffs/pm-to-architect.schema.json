{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PM to Architect Handoff Schema",
  "description": "Validates the technical intent payload from Phase 2 (PM) to Phase 3 (Architect). Ensures all required context for architecture decisions is present.",
  "type": "object",
  "required": ["functional_requirements", "non_functional_requirements", "user_stories", "constraints", "domain_context"],
  "properties": {
    "functional_requirements": {
      "type": "array",
      "description": "List of functional requirements extracted from PRD epics/stories",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "priority"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Requirement ID (e.g., FR-001 or story ID E01-S01)"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "priority": {
            "type": "string",
            "enum": ["must-have", "should-have", "could-have", "wont-have"]
          },
          "source_story": {
            "type": "string",
            "description": "PRD story ID this requirement traces to"
          }
        }
      }
    },
    "non_functional_requirements": {
      "type": "array",
      "description": "NFRs: performance, security, scalability, etc.",
      "items": {
        "type": "object",
        "required": ["id", "category", "description", "metric"],
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": ["performance", "security", "scalability", "reliability", "usability", "maintainability", "compliance", "accessibility"]
          },
          "description": {
            "type": "string"
          },
          "metric": {
            "type": "string",
            "description": "Measurable criterion (e.g., '<200ms response time')"
          }
        }
      }
    },
    "user_stories": {
      "type": "array",
      "description": "All user stories with IDs for traceability",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "acceptance_criteria"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^E\\d+-S\\d+$"
          },
          "title": {
            "type": "string"
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "priority": {
            "type": "string"
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "description": "Technical and business constraints for the architect",
      "properties": {
        "budget": {
          "type": "string"
        },
        "timeline": {
          "type": "string"
        },
        "technology_restrictions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "team_capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "regulatory": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "domain_context": {
      "type": "object",
      "description": "Domain knowledge from upstream phases",
      "required": ["domain", "problem_statement"],
      "properties": {
        "domain": {
          "type": "string"
        },
        "problem_statement": {
          "type": "string",
          "minLength": 20
        },
        "stakeholders": {
          "type": "array",
          "items": { "type": "string" }
        },
        "personas": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "technology_preferences": {
      "type": "object",
      "description": "Optional technology preferences from stakeholders",
      "properties": {
        "preferred": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
