{
  "$schema": "https://code.visualstudio.com/schemas/copilot-hooks.json",
  "description": "AutoNav (JumpStart) VS Code workspace hooks for lifecycle guardrails, traceability, schema validation, and session analytics.",
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/workspace-fingerprint.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/phase-gate-status.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/timeline-warmup.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/session-start.mjs"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/prompt-classifier.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/ambiguity-detector.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/qa-log-capture.mjs"
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/pre-compact.mjs"
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/block-agent-self-modification.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/secrets-path-blocker.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/dangerous-operation-escalator.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/dependency-risk-precheck.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/simplicity-gate-guard.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/phase-boundary-guard.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/spec-drift-guard.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/inject-adr-context.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/capture-plan.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/retry-escalation.mjs"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/schema-on-write-validator.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/spec-graph-updater.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/enforce-test-cochange.mjs"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/session-analytics.mjs"
      },
      {
        "type": "command",
        "command": "node ${workspaceFolder}/.github/hooks/draft-changelog.mjs"
      }
    ]
  }
}
